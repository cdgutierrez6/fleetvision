{
  "name": "@fleetvision/frontend",
  "version": "0.0.1",
  "scripts": {
    "serve:shell": "nx serve shell --port=4200",
    "serve:mfe-fleet": "nx serve mfe-fleet --port=4201",
    "serve:mfe-alerts": "nx serve mfe-alerts --port=4202",
    "serve:mfe-monitoring": "nx serve mfe-monitoring --port=4203",
    "serve:mfe-admin": "nx serve mfe-admin --port=4204",
    "serve:mfe-reports": "nx serve mfe-reports --port=4205",
    "serve:mfe-billing": "nx serve mfe-billing --port=4206",
    "serve:all": "nx run-many -t serve --parallel=7",
    "build": "nx run-many -t build",
    "build:prod": "nx run-many -t build --configuration=production"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@microsoft/signalr": "^8.0.7",
    "@ngrx/signals": "^21.0.0",
    "angular-oauth2-oidc": "^17.0.0",
    "es-module-shims": "^2.8.1",
    "leaflet": "^1.9.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-architects/native-federation": "^21.0.0",
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@nx/angular": "^21.0.0",
    "@nx/js": "^21.0.0",
    "@types/leaflet": "^1.9.14",
    "@types/node": "^22.0.0",
    "nx": "^21.0.0",
    "typescript": "~5.9.0"
  }
}
