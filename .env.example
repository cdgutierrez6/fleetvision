# ============================================================
# FleetVision — Environment Variables Template
# ============================================================
# Copia este archivo a .env y completa los valores.
# NUNCA subas .env al repositorio.
#
# Uso: cp .env.example .env
# ============================================================

# ─── PostgreSQL (servicios de dominio) ───────────────────────
POSTGRES_PORT=5432
POSTGRES_USER=fv_admin
# Cambiar en producción — mínimo 32 caracteres aleatorios
POSTGRES_PASSWORD=CHANGE_ME_postgres_dev_password

# ─── TimescaleDB (telemetría) ────────────────────────────────
TIMESCALEDB_PORT=5433
TIMESCALE_DB=telemetry_db
TIMESCALE_USER=telemetry_user
TIMESCALE_PASSWORD=CHANGE_ME_timescale_dev_password

# ─── Kafka KRaft ─────────────────────────────────────────────
# Genera el cluster ID con:
#   docker run --rm confluentinc/cp-kafka:7.7.1 kafka-storage random-uuid
# El ID debe ser un UUID base64url de 22 caracteres.
KAFKA_CLUSTER_ID=CHANGE_ME_run_kafka_storage_random_uuid

# ─── Schema Registry ─────────────────────────────────────────
SCHEMA_REGISTRY_PORT=8081

# ─── Redis ───────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_dev_password

# ─── Observabilidad ──────────────────────────────────────────
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_dev_password

# ─── Jaeger (OTLP) ───────────────────────────────────────────
JAEGER_UI_PORT=16686
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318

# ─── Stripe (Billing) ────────────────────────────────────────
# Obtener en: https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ─── Azure (Producción) ──────────────────────────────────────
AZURE_TENANT_ID=CHANGE_ME
AZURE_SUBSCRIPTION_ID=CHANGE_ME
AZURE_KEYVAULT_NAME=CHANGE_ME
AZURE_CONTAINER_REGISTRY=CHANGE_ME.azurecr.io

# ─── JWT / OpenIddict ────────────────────────────────────────
# Mínimo 64 caracteres aleatorios para producción
JWT_SIGNING_KEY=CHANGE_ME_minimum_64_chars_random_signing_key_for_development_only
JWT_ENCRYPTION_KEY=CHANGE_ME_minimum_64_chars_random_encryption_key_dev_only
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=30

# ─── Email (Notificaciones) ──────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=noreply@fleetvision.com
