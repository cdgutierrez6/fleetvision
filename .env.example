# ============================================================
# FleetVision — Variables de Entorno de Desarrollo
# Copiar a .env y completar antes de docker compose up
# NUNCA commitear .env con valores reales
# ============================================================

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=fv_admin
POSTGRES_PASSWORD=CHANGE_ME_min32chars_postgres_password
POSTGRES_PORT=5434

# ─── TimescaleDB ──────────────────────────────────────────
TIMESCALE_DB=telemetry_db
TIMESCALE_USER=telemetry_user
TIMESCALE_PASSWORD=CHANGE_ME_min32chars_timescale_password
TIMESCALEDB_PORT=5435

# ─── Kafka ────────────────────────────────────────────────
# Generar con: docker run --rm confluentinc/cp-kafka:7.7.1 kafka-storage random-uuid
KAFKA_CLUSTER_ID=CHANGE_ME_run_kafka-storage_random-uuid
SCHEMA_REGISTRY_PORT=8081

# ─── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_min32chars_redis_password
REDIS_PORT=6380

# ─── Observabilidad ───────────────────────────────────────
JAEGER_UI_PORT=16686
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password

# ─── JWT (compartido entre Identity y Gateway) ────────────
# Minimo 64 caracteres - si cambia, todos los tokens existentes se invalidan
JWT_SIGNING_KEY=CHANGE_ME_minimum_64_chars_jwt_signing_key_for_fleetvision_platform

# ─── Application Services ─────────────────────────────────
IDENTITY_PORT=5001
GATEWAY_PORT=5000
TENANT_MGMT_PORT=5002
BILLING_PORT=5003
FLEET_ASSETS_PORT=5004
TELEMETRY_PORT=5005
GEOFENCING_PORT=5006
PREDICTIVE_MAINTENANCE_PORT=5007
REPORTING_PORT=5008
NOTIFICATIONS_PORT=5009

# ─── Stripe Billing ───────────────────────────────────────
# Obtener en https://dashboard.stripe.com/apikeys (modo test)
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
# Obtener al registrar el webhook endpoint en Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
# IDs de precios en Stripe (crear en Products → Prices)
STRIPE_PRICE_STARTER_ID=price_CHANGE_ME_starter
STRIPE_PRICE_PROFESSIONAL_ID=price_CHANGE_ME_professional
STRIPE_PRICE_ENTERPRISE_ID=price_CHANGE_ME_enterprise
# Clave interna para llamadas service-to-service (min 32 chars)
INTERNAL_API_KEY=CHANGE_ME_min32chars_internal_api_key
