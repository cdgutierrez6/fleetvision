{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "IdentityDb": "Host=localhost;Port=5434;Database=identity_db;Username=fv_admin;Password=${POSTGRES_PASSWORD}"
  },
  "Jwt": {
    "Issuer": "fleetvision-identity",
    "Audience": "fleetvision-api",
    "AccessTokenTtlMinutes": 15,
    "SigningKey": "SET_VIA_ENVIRONMENT_VARIABLE_OR_SECRETS"
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:4317"
  },
  "Cors": {
    "Origins": [ "http://localhost:4200" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  }
}
