{
  "ConnectionStrings": {
    "BillingDb": "Host=localhost;Port=5434;Database=billing_db;Username=fv_admin;Password=${POSTGRES_PASSWORD}"
  },
  "Jwt": {
    "SigningKey": "${JWT_SIGNING_KEY}"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092"
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:4317"
  },
  "TenantManagement": {
    "BaseUrl": "http://localhost:5002",
    "InternalApiKey": "${INTERNAL_API_KEY}"
  },
  "Stripe": {
    "SecretKey": "${STRIPE_SECRET_KEY}",
    "WebhookSecret": "${STRIPE_WEBHOOK_SECRET}",
    "PriceIds": {
      "Starter": "${STRIPE_PRICE_STARTER_ID}",
      "Professional": "${STRIPE_PRICE_PROFESSIONAL_ID}",
      "Enterprise": "${STRIPE_PRICE_ENTERPRISE_ID}"
    },
    "SuccessUrl": "http://localhost:4200/billing/success",
    "CancelUrl": "http://localhost:4200/billing/cancel"
  }
}
