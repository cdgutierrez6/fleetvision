{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Jwt": {
    "Issuer": "fleetvision-identity",
    "Audience": "fleetvision-api"
  },
  "OpenTelemetry": {
    "Endpoint": "http://jaeger:4317"
  },
  "Maintenance": {
    "OdometerThresholdKm": 10000,
    "TimeBasedDays": 180
  }
}
