{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information"
      }
    }
  },
  "Jwt": {
    "Issuer":     "fleetvision-identity",
    "Audience":   "fleetvision-api",
    "SigningKey":  "dev-signing-key-must-be-at-least-64-characters-long-for-hs256-hmac"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092"
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:4317"
  }
}
