{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Jwt": {
    "Issuer":   "fleetvision-identity",
    "Audience": "fleetvision-api"
  },
  "Kafka": {
    "BootstrapServers": ""
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:4317"
  },
  "AllowedHosts": "*"
}
